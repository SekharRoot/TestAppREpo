{
  "entities": {
    "User": {
      "title": "User",
      "description": "Teacher profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Course": {
      "title": "Course",
      "description": "Syllabus and course details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string", "description": "UID of the teacher who owns this course" },
        "title": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "semester": { "type": "string" },
        "year": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "title"]
    },
    "Material": {
      "title": "Material",
      "description": "Course materials like documents or links",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["link", "file", "note"] },
        "url": { "type": "string" },
        "content": { "type": "string", "description": "Optional text content or notes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course syllabi"
    },
    "/courses/{courseId}/materials/{materialId}": {
      "schema": "Material",
      "description": "Materials for a course"
    }
  }
}
